{
  "Diagnostics": {
    "IncludeExceptionDetailsInResponse": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AgentAutoExecutionDispatchPolicy": {
    "MaxAutoStartPerMessage": 3,
    "MaxActiveExecutionsPerSession": 3,
    "MaxDynamicAutoStartPerMessage": 0,
    "MaxDynamicActiveExecutionsPerSession": 0,
    "AllowedLevels": [
      "Bug",
      "Task"
    ],
    "DynamicAllowedLevels": [
      "Feature",
      "Component",
      "Bug",
      "Task"
    ]
  }
}
