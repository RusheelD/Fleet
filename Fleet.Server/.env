# Fleet.Server (.env)
# Runtime environment variables for standalone server deployment.
# Use the same key names in GitHub Secrets and Azure App Settings.

# ASP.NET Core host
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_HTTP_PORTS=8080
GIT_EXECUTABLE_PATH=/usr/bin/git
REPO_SANDBOX_ROOT=/tmp/fleet-sandboxes
DataProtection__KeysPath=/home/aspnet/DataProtection-Keys

# Database and cache
ConnectionStrings__fleetdb=Host=YOUR_POSTGRES_HOST;Port=5432;Database=fleetdb;Username=YOUR_POSTGRES_USER;Password=YOUR_POSTGRES_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
# Optional: if unset, Fleet falls back to in-memory output caching.
ConnectionStrings__cache=YOUR_REDIS_HOST:6379,password=YOUR_REDIS_PASSWORD,ssl=True,abortConnect=False

# Microsoft Entra ID (backend API app registration)
AZUREAD__INSTANCE=https://fleetaidev.ciamlogin.com/
AZUREAD__TENANTID=c958def2-e065-48c9-99e0-8e28431dfcd7
AZUREAD__CLIENTID=73df32d0-82b8-4eba-bc4a-6df3d1f0a281
AZUREAD__AUDIENCE=api://73df32d0-82b8-4eba-bc4a-6df3d1f0a281
AZUREAD__REQUIREDSCOPE=access_as_user

# CORS allow-list (frontend + website)
AllowedOrigins__0=https://app.your-domain.com
AllowedOrigins__1=https://your-domain.com

# GitHub OAuth app (server-side token exchange)
GitHub__ClientId=YOUR_GITHUB_OAUTH_CLIENT_ID
GitHub__ClientSecret=YOUR_GITHUB_OAUTH_CLIENT_SECRET

# LLM provider config (required for chat/agent features)
LLM__Provider=azure-openai
LLM__Endpoint=https://YOUR_AZURE_OPENAI_RESOURCE.openai.azure.com/openai/responses?api-version=2025-04-01-preview
LLM__ApiKey=YOUR_AZURE_OPENAI_API_KEY
LLM__Model=gpt-5.2-codex
LLM__GenerateModel=gpt-5.2-codex
LLM__TimeoutSeconds=1800
LLM__GenerateTimeoutSeconds=1800

# Optional fallback keys read by Fleet.Server
# AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
# AZURE_OPENAI_ENDPOINT=https://YOUR_AZURE_OPENAI_RESOURCE.openai.azure.com/openai/responses?api-version=2025-04-01-preview

# Optional telemetry
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otlp-endpoint:4317

# Optional admin/unlimited overrides (array syntax)
# Admin__AllowedEntraObjectIds__0=00000000-0000-0000-0000-000000000000
# Admin__AllowedEmails__0=admin@your-domain.com
# UserRoles__UnlimitedEntraObjectIds__0=00000000-0000-0000-0000-000000000000
# UserRoles__UnlimitedEmails__0=owner@your-domain.com
