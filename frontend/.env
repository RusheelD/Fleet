# Fleet frontend (.env)
# Used by Vite for local/default builds.

# Microsoft Entra ID SPA app registration
VITE_ENTRA_CLIENT_ID=YOUR_ENTRA_SPA_CLIENT_ID
VITE_ENTRA_AUTHORITY=https://YOUR_ENTRA_TENANT_NAME.ciamlogin.com/YOUR_ENTRA_TENANT_ID
VITE_ENTRA_API_SCOPE=api://YOUR_API_APP_CLIENT_ID/access_as_user
VITE_ENTRA_KNOWN_AUTHORITIES=YOUR_ENTRA_TENANT_NAME.ciamlogin.com

# App environment label: development | staging | production
VITE_ENVIRONMENT=production

# Public site URL (used for "back to site" links)
VITE_WEBSITE_URL=https://your-domain.com

# GitHub OAuth app client ID (needed for "Connect GitHub")
VITE_GITHUB_CLIENT_ID=YOUR_GITHUB_OAUTH_CLIENT_ID

# Optional: local dev proxy override (not used in production build output)
# VITE_API_PROXY_TARGET=https://api.your-domain.com
