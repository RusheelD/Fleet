# Fleet frontend (.env)
# Shared defaults for Vite builds.
#
# Do not put placeholder Entra values here: this file is loaded for every
# mode, and broken defaults can leak into deployed bundles. Use
# `frontend/.env.example` as a template, or set real VITE_ENTRA_* values in
# the environment that runs the build.

# App environment label: development | staging | production
VITE_ENVIRONMENT=production

# Public site URL (used for "back to site" links)
VITE_WEBSITE_URL=https://your-domain.com

# Optional: local dev proxy override (not used in production build output)
# VITE_API_PROXY_TARGET=https://api.your-domain.com
