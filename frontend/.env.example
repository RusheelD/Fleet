# Microsoft Entra ID Configuration
# Copy this file to .env and fill in your values from the Azure portal.
# GitHub Actions production builds use secrets with these same VITE_* names.

# Application (client) ID from your Entra ID SPA app registration
VITE_ENTRA_CLIENT_ID=your-client-id-here

# External ID authority URL - https://{tenant-name}.ciamlogin.com/{tenant-id}
VITE_ENTRA_AUTHORITY=https://your-tenant-name.ciamlogin.com/your-tenant-id-here

# Exact redirect URI registered for the SPA app
VITE_ENTRA_REDIRECT_URI=https://app.your-domain.com/

# Known authority host(s) for CIAM - comma-separated when more than one is needed
VITE_ENTRA_KNOWN_AUTHORITIES=your-tenant-name.ciamlogin.com

# API scope - api://{apiClientId}/access_as_user
VITE_ENTRA_API_SCOPE=api://your-api-client-id/access_as_user

# Optional provider hints (defaults shown)
# VITE_ENTRA_GOOGLE_DOMAIN_HINT=google.com
# VITE_ENTRA_GITHUB_DOMAIN_HINT=github.com
# VITE_ENTRA_GOOGLE_IDP_HINT=google.com
# VITE_ENTRA_GITHUB_IDP_HINT=github.com

# Environment: development | staging | production
VITE_ENVIRONMENT=development

# URL of the marketing website (for "back to website" links)
VITE_WEBSITE_URL=https://fleet-ai.dev

# Optional GitHub OAuth client ID. If omitted, Fleet will ask the backend for it.
# VITE_GITHUB_CLIENT_ID=your-github-oauth-client-id

# Optional API origin override. Leave unset to use same-origin /api requests.
# Example: VITE_API_ORIGIN=https://fleet-ai-dev.azurewebsites.net
