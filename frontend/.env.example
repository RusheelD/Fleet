# Microsoft Entra ID (Azure AD) Configuration
# Copy this file to .env and fill in your values from the Azure portal.

# Application (client) ID from your Entra ID app registration
VITE_ENTRA_CLIENT_ID=your-client-id-here

# Authority URL — https://login.microsoftonline.com/{tenantId}
VITE_ENTRA_AUTHORITY=https://login.microsoftonline.com/your-tenant-id-here

# Optional: comma-separated trusted authority hosts for CIAM/B2C tenants
# VITE_ENTRA_KNOWN_AUTHORITIES=your-tenant.ciamlogin.com

# API scope — api://{apiClientId}/access_as_user
VITE_ENTRA_API_SCOPE=api://your-api-client-id/access_as_user

# Optional social-provider authorities (use when Google/GitHub sign-in is configured
# through Entra External ID / B2C user flows).
# For the most reliable "Sign in with Google" experience, set Google authority
# to a Google-only user flow.
# VITE_ENTRA_GOOGLE_AUTHORITY=https://your-tenant.ciamlogin.com/your-tenant.onmicrosoft.com/B2C_1_signup_signin_google
# VITE_ENTRA_GITHUB_AUTHORITY=https://your-tenant.ciamlogin.com/your-tenant.onmicrosoft.com/B2C_1_signup_signin_github

# Environment: development | staging | production
VITE_ENVIRONMENT=development

# URL of the marketing website (for "back to website" links)
VITE_WEBSITE_URL=https://fleet-ai.dev

# Optional API origin override. Leave unset to use same-origin /api requests.
# Example: VITE_API_ORIGIN=https://fleet-ai-dev.azurewebsites.net
