# Fleet.AppHost (.env)
# Inputs consumed by AppHost to inject Fleet.Server runtime secrets/env vars.

# Preferred AppHost secret keys (mapped to config paths)
Secrets__AzureOpenAiApiKey=YOUR_AZURE_OPENAI_API_KEY
Secrets__AzureOpenAiEndpoint=https://YOUR_AZURE_OPENAI_RESOURCE.openai.azure.com/openai/responses?api-version=2025-04-01-preview
Secrets__AzureOpenAiModel=gpt-5.2-codex
Secrets__AzureOpenAiTimeoutSeconds=1800
Secrets__AzureOpenAiGenerateTimeoutSeconds=1800
Secrets__GitHubClientSecret=YOUR_GITHUB_OAUTH_CLIENT_SECRET

# Optional fallback keys also read by AppHost
# AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
# AZURE_OPENAI_ENDPOINT=https://YOUR_AZURE_OPENAI_RESOURCE.openai.azure.com/openai/responses?api-version=2025-04-01-preview
# LLM__Model=gpt-5.2-codex
# LLM__TimeoutSeconds=1800
# LLM__GenerateTimeoutSeconds=1800
# GITHUB__CLIENTSECRET=YOUR_GITHUB_OAUTH_CLIENT_SECRET
